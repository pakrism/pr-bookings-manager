rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return signedIn() && userDoc().data.isActive == true;
    }

    function role() {
      return userDoc().data.role;
    }

    function isAdmin() {
      return isActiveUser() && (role() == 'admin' || role() == null || role() == '');
    }

    function isBookingManager() {
      return isActiveUser() && role() == 'booking_manager';
    }

    function managerBookedBy() {
      return userDoc().data.bookedBy;
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isActiveUser();
      allow create: if isAdmin() || (
        isBookingManager()
        && request.resource.data.bookedBy == managerBookedBy()
      );
      allow update, delete: if isAdmin() || (
        isBookingManager()
        && resource.data.bookedBy == managerBookedBy()
        && request.resource.data.bookedBy == managerBookedBy()
      );
    }

    match /packages/{packageId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /counters/{counterId} {
      allow read: if isAdmin() || isBookingManager();
      allow write: if isAdmin() || isBookingManager();
    }
  }
}
